# Application Settings
APP_NAME=ATTREQ
APP_ENV=development
APP_DEBUG=true

# Database Configuration
DATABASE_URL=postgresql+asyncpg://attreq_user:attreq_password@localhost:5432/attreq_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=attreq_db
POSTGRES_USER=attreq_user
POSTGRES_PASSWORD=attreq_password

# JWT Configuration
SECRET_KEY=your-secret-key-here-generate-with-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS Configuration
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000","https://attreq.vercel.app"]
TRUSTED_HOSTS=["attreq.com","*.attreq.com","localhost","127.0.0.1"]

# Google OAuth (Optional - Phase 2)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# External APIs
OPENWEATHER_API_KEY=
GEMINI_API_KEY=

# File Upload Settings
MAX_UPLOAD_SIZE_MB=10
UPLOAD_DIR=./uploads
